# Application
NODE_ENV=development
PORT=3000

# Simulation execution (11_インフラストラクチャ設計.md「設定項目」)
# ワーカー内戦闘実行の期限(ms)。超過すると504 EXECUTION_TIMEOUTを返す。
SIMULATION_TIMEOUT_MS=30000
# Worker Poolの待機タスク上限。満杯時は503 CAPACITY_EXCEEDEDを返す。
WORKER_MAX_QUEUE=100

# Graceful Shutdown (11_インフラストラクチャ設計.md「Graceful Shutdown」)
# SIGTERM/SIGINT受信後、実行中タスクを待つ上限(ms)。超過分は強制キャンセルする。
SHUTDOWN_GRACE_MS=30000

# Logging
LOG_LEVEL=info

# CORS (11_インフラストラクチャ設計.md「CORS」)
# GitHub Pages UIなどbrowserからのcross-origin requestを許可するorigin。
# comma区切り・完全一致のみ。schemeとhostだけを持つ絶対origin（path/query/
# fragment/userinfo/wildcard/重複は起動エラー）。未設定時は全origin拒否。
# 本番: CORS_ALLOWED_ORIGINS=https://komei0727.github.io
CORS_ALLOWED_ORIGINS=http://localhost:5173
